pipeline {
    agent any

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Premchand-96/static-website.git'
            }
        }

        stage('Deploy to Server') {
            steps {
                // This forces Jenkins to be in the workspace directory
                dir("${WORKSPACE}") {
                    sh '''
                    # 1. Force remove old files
                    sudo rm -rf /var/www/html/*
                    
                    # 2. Copy everything from current folder to Apache
                    sudo cp -r . /var/www/html/
                    
                    # 3. Set ownership so Apache can serve it
                    sudo chown -R apache:apache /var/www/html
                    sudo chmod -R 755 /var/www/html
                    
                    # 4. Restart Apache to reflect changes
                    sudo systemctl restart httpd
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD Successful! View at http://13.53.40.0"
        }
    }
}
