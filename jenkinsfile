pipeline {
    agent any

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Premchand-96/static-website.git'
            }
        }

        stage('Deploy to Server') {
    steps {
        sh '''
        # -f ignores errors if the directory is already empty
        sudo rm -rf /var/www/html/*
        
        # Copy everything from workspace to the web root
        sudo cp -r ./* /var/www/html/
        
        # Set final permissions so Apache can serve the site
        sudo chown -R apache:apache /var/www/html
        sudo chmod -R 755 /var/www/html
        
        # Restart Apache to refresh the site
        sudo systemctl restart httpd
        '''
    }
}

        stage('Restart Apache') {
            steps {
                sh 'sudo systemctl restart httpd'
            }
        }
    }

    post {
        success {
            echo "Successfully deployed! Check http://13.53.40.0"
        }
        failure {
            echo "Deployment failed. Check the Jenkins Console Output for errors."
        }
    }
}
