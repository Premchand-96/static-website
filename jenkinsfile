pipeline {
    agent any

    environment {
        EC2_USER = "ec2-user"
        EC2_HOST = "13.53.40.0"
        WEB_DIR  = "/var/www/html"
    }

    stages {

        stage('Clone GitHub Repository') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/premchand-96/static-website.git'
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(['jenkins']) {
                    sh """
                    scp -o StrictHostKeyChecking=no index.html $EC2_USER@$EC2_HOST:/tmp/

                    ssh -o StrictHostKeyChecking=no $EC2_USER@$EC2_HOST '
                        sudo rm -rf $WEB_DIR/*
                        sudo cp /tmp/index.html $WEB_DIR/
                        sudo chown -R apache:apache $WEB_DIR
                        sudo systemctl restart httpd
                    '
                    """
                }
            }
        }
    }
}
