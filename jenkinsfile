pipeline {
    agent any

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Premchand-96/static-website.git'
            }
        }

        stage('Deploy & Restart') {
            steps {
                dir("${WORKSPACE}") {
                    sh '''
                    # 1. Clear out old files
                    sudo rm -rf /var/www/html/*
                    
                    # 2. Copy the new files from workspace to web root
                    sudo cp -r . /var/www/html/
                    
                    # 3. Set the correct permissions for Apache
                    sudo chown -R apache:apache /var/www/html
                    sudo chmod -R 755 /var/www/html
                    
                    # 4. Restart the web server
                    sudo systemctl restart httpd
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "CI/CD Successful! Check http://13.53.40.0"
        }
        failure {
            echo "Deployment failed. Check Jenkins Console Output."
        }
    }
}
