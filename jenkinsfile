pipeline {
    agent any

    environment {
        DEPLOY_DIR = "/var/www/html"
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs() 
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Premchand-96/static-website.git'
            }
        }

        stage('Deploy to Server') {
            steps {
                sh '''
                # 1. Force remove everything in the web directory to be clean
                sudo rm -rf ${DEPLOY_DIR}/*
                
                # 2. Copy new files from Jenkins workspace to Apache root
                sudo cp -r ./* ${DEPLOY_DIR}/
                
                # 3. Set permissions (Universal for Amazon Linux/CentOS)
                sudo chmod -R 755 ${DEPLOY_DIR}
                '''
            }
        }

        stage('Restart Web Server') {
            steps {
                // Using 'reload' is faster and doesn't drop connections
                sh 'sudo systemctl reload httpd || sudo systemctl restart httpd'
            }
        }
    }

    post {
        success {
            echo "✅ Deployment Successful! View here: http://13.53.40.0"
        }
        failure {
            echo "❌ Deployment Failed. Check Jenkins Console Output."
        }
    }
}
