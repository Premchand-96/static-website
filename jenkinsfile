pipeline {
    agent any

    environment {
        DEPLOY_DIR = "/var/www/html"
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Premchand-96/static-website.git'
            }
        }

        stage('Deploy to Server') {
            steps {
                sh '''
                # Remove default apache index if it exists
                sudo rm -f $DEPLOY_DIR/index.html
                # Copy all files from workspace to web root
                sudo cp -r ./* $DEPLOY_DIR/
                # Ensure permissions are correct for the web server
                sudo chown -R ec2-user:apache $DEPLOY_DIR
                sudo chmod -R 755 $DEPLOY_DIR
                '''
            }
        }

        stage('Restart Web Server') {
            steps {
                sh 'sudo systemctl restart httpd'
            }
        }
    }

    post {
        success {
            echo "Deployment Successful! Visit http://13.53.40.0"
        }
    }
}
