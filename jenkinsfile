pipeline {
    agent any

    stages {
        stage('Deploy Website') {
            steps {
                // 1. Pull the latest code from GitHub
                git branch: 'main', url: 'https://github.com/Premchand-96/static-website.git'
                
                // 2. Run all deployment commands in one block
                sh '''
                # Move to workspace to be certain
                cd ${WORKSPACE}

                # Clear out the Apache folder
                sudo rm -rf /var/www/html/*
                
                # Copy files directly (not the folder, but the contents)
                sudo cp -r . /var/www/html/
                
                # Set permissions so the web server can read the files
                sudo chown -R apache:apache /var/www/html
                sudo chmod -R 755 /var/www/html
                
                # Restart Apache to refresh
                sudo systemctl restart httpd
                '''
            }
        }
    }

    post {
        success {
            echo "CI/CD Completed! Check http://13.53.40.0"
        }
        failure {
            echo "CI/CD Failed. Check the Console Output below for the specific error."
        }
    }
}
